# =============================================================================
# task-manager 环境变量示例文件
# 复制此文件为 .env，填写真实值后再使用
#
# ⚠️  安全须知：
#   1. .env 已被 .gitignore 排除，严禁将含真实密钥的 .env 提交到版本库
#   2. JWT_SECRET 必须替换为强随机字符串（生成：openssl rand -hex 32）
#   3. SMTP_PASSWORD 等凭证统一通过本文件或环境变量注入
#
# 后端（Go）完整 TASK_MANAGER_* 键名模板见：ops-timer-backend/env.example
# =============================================================================

# JWT 签名密钥（生产环境必须替换，至少 32 位随机字符串）
# 生成方式：openssl rand -hex 32
# docker-compose 会将其注入为 TASK_MANAGER_AUTH_JWT_SECRET
JWT_SECRET=

# 初始管理员密码（仅首次无用户时生效，之后修改不影响已有账户）
# TASK_MANAGER_INIT_ADMIN_PASSWORD=

# SMTP 邮件发送（不填则不启用邮件通知）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password_or_app_token
SMTP_FROM=运维任务管理器 <noreply@example.com>

# MCP（AI 智能体接入）
MCP_ENABLED=true
MCP_PATH=/mcp

# 数据库（默认 SQLite，通常不需要修改）
# DB_DRIVER=sqlite
# DB_DSN=./data/task_manager.db
