page { background: var(--td-bg-color-page); }
.page { height: 100vh; display: flex; flex-direction: column; }

/* 月份导航 */
.month-nav {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--td-bg-color-container);
  border-bottom: 1rpx solid var(--td-border-level-1-color);
  flex-shrink: 0;
}
.month-btn { padding: 8rpx; }
.month-label { flex: 1; text-align: center; font-size: 32rpx; font-weight: 600; color: var(--td-text-color-primary); }
.today-btn {
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--td-text-color-disabled);
  border-radius: var(--td-radius-extra-large);
  margin-right: 16rpx;
}
.today-text { font-size: 24rpx; color: var(--td-text-color-secondary); }
.add-btn {
  width: 64rpx; height: 64rpx;
  background: var(--td-brand-color);
  border-radius: var(--td-radius-extra-large);
  display: flex; align-items: center; justify-content: center;
}

.loading-wrap { display: flex; justify-content: center; padding: 100rpx 0; }

.empty-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0; gap: 20rpx;
}
.empty-text { font-size: 28rpx; color: var(--td-text-color-placeholder); }

/* 日程列表 */
.schedule-list { flex: 1; }

.date-group { padding: 0 24rpx; }

.date-header {
  display: flex; align-items: center;
  padding: 28rpx 0 16rpx;
  gap: 12rpx;
}
.date-dot {
  width: 12rpx; height: 12rpx;
  background: var(--td-brand-color); border-radius: 50%;
  flex-shrink: 0;
}
.date-label { font-size: 26rpx; font-weight: 600; color: var(--td-brand-color); }

.schedule-card {
  display: flex;
  align-items: center;
  background: var(--td-bg-color-container);
  border-radius: var(--td-radius-large);
  margin-bottom: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx var(--td-shadow-1);
}
.sched-color-bar { width: 8rpx; height: 100%; min-height: 80rpx; flex-shrink: 0; }
.sched-body { flex: 1; padding: 20rpx 16rpx; min-width: 0; }
.sched-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.sched-title { font-size: 28rpx; font-weight: 500; color: var(--td-text-color-primary); flex: 1; }
.sched-status { padding: 4rpx 14rpx; border-radius: 12rpx; }
.sched-meta { display: flex; align-items: center; gap: 10rpx; flex-wrap: wrap; }
.sched-time { font-size: 24rpx; color: var(--td-text-color-secondary); }
.sched-location { display: flex; align-items: center; gap: 6rpx; }
.sched-loc-text { font-size: 24rpx; color: var(--td-text-color-secondary); }
.sched-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 10rpx; }
.sched-tag {
  display: flex; align-items: center; gap: 6rpx;
  padding: 4rpx 14rpx;
  background: var(--td-brand-color-light);
  border: 1rpx solid var(--td-brand-color-2);
  border-radius: 12rpx;
}
.sched-tag-text { font-size: 22rpx; color: var(--td-brand-color); }
.sched-tag--removable { padding-right: 8rpx; }

/* 详情面板 */
.dialog-sheet {
  background: var(--td-bg-color-container);
  border-radius: var(--td-radius-extra-large) 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 75vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.dialog-tall { max-height: 90vh; }
.dialog-handle {
  width: 80rpx; height: 8rpx;
  background: var(--td-border-level-1-color);
  border-radius: 4rpx;
  margin: 20rpx auto;
  flex-shrink: 0;
}
.dialog-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40rpx 20rpx;
  border: 1rpx solid var(--td-border-level-1-color);
  flex-shrink: 0;
}
.dialog-title { font-size: 32rpx; font-weight: 600; color: var(--td-text-color-primary); }
.dialog-scroll { flex: 1; overflow: hidden; }
.dialog-body { padding: 32rpx 40rpx 40rpx; }

.detail-header {
  display: flex; align-items: center;
  padding: 0 32rpx 20rpx;
  gap: 16rpx;
  flex-shrink: 0;
}
.detail-color-dot {
  width: 20rpx; height: 20rpx;
  border-radius: 50%; flex-shrink: 0;
}
.detail-title { flex: 1; font-size: 32rpx; font-weight: 600; color: var(--td-text-color-primary); }
.detail-actions { display: flex; gap: 20rpx; }
.detail-body { padding: 0 40rpx 40rpx; overflow-y: auto; }
.detail-row {
  display: flex; align-items: center; gap: 16rpx;
  margin-bottom: 20rpx;
}
.detail-text { font-size: 28rpx; color: var(--td-text-color-secondary); }
.detail-status { padding: 6rpx 16rpx; border-radius: 14rpx; }
.detail-desc {
  padding: 20rpx; background: var(--td-bg-color-page);
  border-radius: 12rpx; margin-bottom: 20rpx;
}
.detail-desc-text { font-size: 26rpx; color: var(--td-text-color-secondary); line-height: 1.7; }
.detail-resources { margin-top: 20rpx; }
.detail-sec-title { font-size: 26rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 16rpx; }
.resource-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 20rpx;
  background: var(--td-brand-color-light); border-radius: 12rpx; margin-bottom: 10rpx;
}
.resource-title { font-size: 26rpx; color: var(--td-text-color-primary); }
.resource-type { padding: 4rpx 12rpx; background: var(--td-bg-color-container); border-radius: 10rpx; }
.resource-type-text { font-size: 22rpx; color: var(--td-brand-color); }

/* 表单 */
.field-wrap { margin-bottom: 28rpx; }
.field-label { font-size: 26rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 12rpx; }
.field-row { display: flex; gap: 24rpx; }
.field-half { flex: 1; }
.picker-btn {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 20rpx; background: var(--td-bg-color-page);
  border-radius: 12rpx; font-size: 28rpx; color: var(--td-text-color-primary);
}
.color-row { display: flex; gap: 16rpx; flex-wrap: wrap; }
.color-dot {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  border: 4rpx solid transparent;
}
.color-dot--active { border-color: var(--td-text-color-primary); transform: scale(1.2); }
.tag-input-row { display: flex; gap: 16rpx; align-items: flex-start; }
.btn-row { display: flex; gap: 20rpx; margin-top: 8rpx; }
