page { background: var(--td-bg-color-page); }
.page { min-height: 100vh; }
.loading-wrap { display: flex; justify-content: center; padding: 100rpx 0; }
.content { padding: 24rpx; }

.unit-card {
  background: var(--td-bg-color-container); border-radius: var(--td-radius-extra-large);
  padding: 28rpx; margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--td-shadow-1);
  border-left-style: solid;
}
.unit-title { font-size: 36rpx; font-weight: 700; color: var(--td-text-color-primary); display: block; margin-bottom: 16rpx; }
.unit-meta { display: flex; flex-wrap: wrap; gap: 10rpx; }
.meta-tag { padding: 6rpx 16rpx; border-radius: 14rpx; }
.progress-wrap { margin-top: 28rpx; }
.progress-text { font-size: 32rpx; font-weight: 600; color: var(--td-text-color-primary); display: block; margin-bottom: 16rpx; }
.progress-bar-wrap { display: flex; align-items: center; gap: 16rpx; }
.progress-bar-bg { flex: 1; height: 12rpx; background: var(--td-bg-color-page); border-radius: 6rpx; overflow: hidden; }
.progress-bar-fill { height: 100%; border-radius: 6rpx; transition: width 0.3s; }
.progress-pct { font-size: 24rpx; color: var(--td-text-color-secondary); flex-shrink: 0; }
.unit-desc { margin-top: 20rpx; padding-top: 20rpx; border: 1rpx solid var(--td-border-level-1-color); }
.unit-desc-text { font-size: 26rpx; color: var(--td-text-color-secondary); line-height: 1.7; }

.actions-card {
  background: var(--td-bg-color-container); border-radius: var(--td-radius-extra-large);
  padding: 28rpx; margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--td-shadow-1);
}
.step-actions { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.step-btn {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  padding: 16rpx 32rpx; background: var(--td-bg-color-page); border-radius: var(--td-radius-large);
}
.step-label { font-size: 24rpx; color: var(--td-text-color-secondary); }
.step-current { display: flex; flex-direction: column; align-items: center; }
.step-num { font-size: 64rpx; font-weight: 700; color: var(--td-text-color-primary); line-height: 1; }
.step-unit { font-size: 24rpx; color: var(--td-text-color-secondary); margin-top: 8rpx; }
.action-row { display: flex; gap: 16rpx; }

.section-title { font-size: 24rpx; color: var(--td-text-color-secondary); padding: 4rpx 8rpx 12rpx; }
.logs-card { background: var(--td-bg-color-container); border-radius: var(--td-radius-extra-large); overflow: hidden; }
.empty-tip { padding: 48rpx 0; text-align: center; }
.empty-text { font-size: 26rpx; color: var(--td-text-color-placeholder); }
.log-item {
  display: flex; align-items: center;
  padding: 20rpx 28rpx; border: 1rpx solid var(--td-border-level-1-color);
}
.log-item:last-child { border-bottom: none; }
.log-delta {
  font-size: 32rpx; font-weight: 700;
  min-width: 80rpx; text-align: center;
}
.log-info { flex: 1; padding: 0 16rpx; }
.log-date { font-size: 22rpx; color: var(--td-text-color-placeholder); display: block; }
.log-note { font-size: 24rpx; color: var(--td-text-color-secondary); display: block; margin-top: 4rpx; }
.log-value { font-size: 26rpx; color: var(--td-text-color-secondary); font-weight: 500; }
