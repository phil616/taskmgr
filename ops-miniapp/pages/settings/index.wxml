<scroll-view scroll-y class="page">
  <!-- 用户信息卡 -->
  <view class="user-card">
    <view class="user-avatar">
      <text class="user-avatar-text">{{user.display_name ? user.display_name[0] : (user.username ? user.username[0] : 'U')}}</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{user.display_name || user.username || '用户'}}</text>
      <text class="user-email">{{user.email || '未设置邮箱'}}</text>
    </view>
  </view>

  <!-- 个人信息 -->
  <view class="section-title">个人信息</view>
  <view class="card">
    <view class="field-wrap">
      <text class="field-label">用户名</text>
      <t-input value="{{profileForm.username}}" bind:change="onUsernameInput" placeholder="用户名" />
    </view>
    <view class="field-wrap">
      <text class="field-label">显示名称</text>
      <t-input value="{{profileForm.display_name}}" bind:change="onDisplayNameInput" placeholder="显示名称" />
    </view>
    <view class="field-wrap">
      <text class="field-label">邮箱 {{smtpEnabled ? '' : '(SMTP 未配置)'}}</text>
      <t-input value="{{profileForm.email}}" bind:change="onEmailInput" placeholder="your@email.com" type="text" />
    </view>
    <view class="field-actions">
      <t-button theme="primary" size="small" loading="{{savingProfile}}" bind:tap="saveProfile">保存信息</t-button>
      <t-button
        wx:if="{{smtpEnabled && profileForm.email}}"
        theme="light"
        size="small"
        loading="{{testingEmail}}"
        bind:tap="testEmail"
      >
        发送测试邮件
      </t-button>
    </view>
  </view>

  <!-- 修改密码 -->
  <view class="section-title">修改密码</view>
  <view class="card">
    <view class="field-wrap">
      <text class="field-label">当前密码</text>
      <t-input value="{{passwordForm.old_password}}" bind:change="onOldPwdInput" type="password" placeholder="请输入当前密码" />
    </view>
    <view class="field-wrap">
      <text class="field-label">新密码</text>
      <t-input value="{{passwordForm.new_password}}" bind:change="onNewPwdInput" type="password" placeholder="请输入新密码" />
    </view>
    <view class="field-wrap">
      <text class="field-label">确认新密码</text>
      <t-input value="{{passwordForm.confirm_password}}" bind:change="onConfirmPwdInput" type="password" placeholder="再次输入新密码" />
    </view>
    <t-button theme="primary" size="small" loading="{{savingPassword}}" bind:tap="changePassword">修改密码</t-button>
  </view>

  <!-- API Token -->
  <view class="section-title">API Token</view>
  <view class="card">
    <text class="tip-text">API Token 可用于脚本和第三方集成调用系统 API，请妥善保管。</text>
    <view class="token-row">
      <text class="token-text">{{showToken ? apiToken : '••••••••••••••••••••'}}</text>
      <view class="token-icon" bind:tap="toggleToken">
        <t-icon name="{{showToken ? 'browse-off' : 'browse'}}" size="36rpx" color="#8e8e93" />
      </view>
      <view class="token-icon" bind:tap="copyToken">
        <t-icon name="page-copy" size="36rpx" color="#007aff" />
      </view>
    </view>
    <t-button theme="warning" size="small" variant="outline" loading="{{regenerating}}" bind:tap="regenerateToken">重新生成</t-button>
  </view>

  <!-- 服务器设置 -->
  <view class="section-title">连接设置</view>
  <view class="card">
    <view class="server-url-row" bind:tap="toggleServerEdit">
      <view class="server-url-info">
        <text class="server-url-label">服务器地址</text>
        <text class="server-url-val">{{serverUrl}}</text>
      </view>
      <t-icon name="chevron-{{showServerEdit ? 'up' : 'down'}}" size="36rpx" color="#8e8e93" />
    </view>
    <view wx:if="{{showServerEdit}}" class="server-edit-panel">
      <t-input
        value="{{serverUrlInput}}"
        bind:change="onServerUrlInput"
        placeholder="http://your-server:8080"
      />
      <t-button theme="primary" size="small" bind:tap="saveServerUrl" style="margin-top:16rpx;">保存地址</t-button>
    </view>
  </view>

  <!-- 退出登录 -->
  <view style="padding:32rpx;">
    <t-button theme="danger" variant="outline" block bind:tap="logout">退出登录</t-button>
  </view>

  <view style="height: calc(120rpx + env(safe-area-inset-bottom));"></view>
</scroll-view>
