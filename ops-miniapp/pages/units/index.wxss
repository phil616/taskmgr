page { background: var(--td-bg-color-page); }
.page { height: 100vh; display: flex; flex-direction: column; }

.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; background: var(--td-bg-color-container); border-bottom: 1rpx solid var(--td-border-level-1-color); flex-shrink: 0;
}
.filter-btn {
  display: flex; align-items: center; gap: 8rpx;
  padding: 12rpx 20rpx; background: var(--td-bg-color-page); border-radius: var(--td-radius-extra-large);
}
.filter-text { font-size: 24rpx; color: var(--td-text-color-secondary); }
.add-btn {
  width: 64rpx; height: 64rpx; background: var(--td-brand-color);
  border-radius: var(--td-radius-extra-large); display: flex; align-items: center; justify-content: center;
}
.loading-wrap { display: flex; justify-content: center; padding: 100rpx 0; }
.empty-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0; gap: 20rpx;
}
.empty-text { font-size: 28rpx; color: var(--td-text-color-placeholder); }

.units-list { flex: 1; padding: 16rpx 24rpx; }

.unit-card {
  display: flex; align-items: stretch;
  background: var(--td-bg-color-container); border-radius: var(--td-radius-large);
  margin-bottom: 12rpx; overflow: hidden;
  box-shadow: 0 2rpx 8rpx var(--td-shadow-1);
}
.unit-card--alert { border-left: 6rpx solid var(--td-error-color-6); }
.unit-left { display: flex; align-items: stretch; flex: 1; min-width: 0; }
.unit-priority-bar { width: 6rpx; flex-shrink: 0; }
.unit-body { flex: 1; padding: 20rpx 16rpx; min-width: 0; }
.unit-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.unit-title { font-size: 28rpx; font-weight: 500; color: var(--td-text-color-primary); flex: 1; }
.unit-type-tag {
  padding: 4rpx 12rpx; background: var(--td-brand-color-light); border-radius: 10rpx; flex-shrink: 0;
}
.unit-type-text { font-size: 20rpx; color: var(--td-brand-color); }
.unit-progress { font-size: 24rpx; display: block; }
.unit-right { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 0 16rpx; gap: 16rpx; }
.unit-status-btn, .unit-edit-btn { padding: 4rpx; }

/* 弹窗 */
.dialog-sheet {
  background: var(--td-bg-color-container); border-radius: var(--td-radius-extra-large) 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 88vh; display: flex; flex-direction: column;
}
.dialog-handle {
  width: 80rpx; height: 8rpx; background: var(--td-border-level-1-color);
  border-radius: 4rpx; margin: 20rpx auto; flex-shrink: 0;
}
.dialog-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40rpx 20rpx; border: 1rpx solid var(--td-border-level-1-color); flex-shrink: 0;
}
.dialog-title { font-size: 32rpx; font-weight: 600; color: var(--td-text-color-primary); }
.dialog-scroll { flex: 1; overflow: hidden; }
.dialog-body { padding: 32rpx 40rpx 40rpx; }
.field-wrap { margin-bottom: 28rpx; }
.field-label { font-size: 26rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 12rpx; }
.field-row { display: flex; gap: 24rpx; }
.field-half { flex: 1; }
.picker-btn {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 20rpx; background: var(--td-bg-color-page); border-radius: 12rpx;
  font-size: 28rpx; color: var(--td-text-color-primary);
}
