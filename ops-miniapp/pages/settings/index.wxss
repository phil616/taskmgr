page { background: var(--td-bg-color-page); }
.page { height: 100vh; }

/* 用户信息卡 */
.user-card {
  display: flex; align-items: center; gap: 24rpx;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, var(--td-brand-color), var(--td-brand-color));
  margin-bottom: 8rpx;
}
.user-avatar {
  width: 96rpx; height: 96rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.user-avatar-text { font-size: 44rpx; font-weight: 700; color: var(--td-bg-color-container); }
.user-info { display: flex; flex-direction: column; }
.user-name { font-size: 36rpx; font-weight: 700; color: var(--td-bg-color-container); }
.user-email { font-size: 24rpx; color: rgba(255,255,255,0.75); margin-top: 8rpx; }

/* 分区标题 */
.section-title {
  font-size: 24rpx; color: var(--td-text-color-secondary);
  padding: 24rpx 32rpx 12rpx;
  letter-spacing: 1rpx;
}

/* 卡片 */
.card {
  background: var(--td-bg-color-container);
  padding: 28rpx 32rpx;
  margin-bottom: 8rpx;
}
.field-wrap { margin-bottom: 24rpx; }
.field-label { font-size: 26rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 10rpx; }
.field-actions { display: flex; gap: 16rpx; margin-top: 8rpx; }
.tip-text { font-size: 24rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 20rpx; line-height: 1.6; }

/* Token */
.token-row {
  display: flex; align-items: center;
  background: var(--td-bg-color-page); border-radius: 12rpx;
  padding: 16rpx 20rpx; margin-bottom: 20rpx; gap: 12rpx;
}
.token-text {
  flex: 1; font-size: 24rpx; color: var(--td-text-color-secondary);
  word-break: break-all; font-family: monospace;
}
.token-icon { padding: 4rpx; flex-shrink: 0; }

/* 服务器设置 */
.server-url-row {
  display: flex; align-items: center; justify-content: space-between;
}
.server-url-info { flex: 1; }
.server-url-label { font-size: 26rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 6rpx; }
.server-url-val { font-size: 24rpx; color: var(--td-text-color-secondary); word-break: break-all; }
.server-edit-panel { margin-top: 20rpx; }
