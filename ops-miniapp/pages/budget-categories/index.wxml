<view class="page">
  <view class="top-bar">
    <picker mode="selector" range="{{['全部','支出','收入','通用']}}" bind:change="onTypeFilterChange">
      <view class="filter-btn">
        <text class="filter-text">{{typeFilter === 'expense' ? '支出' : typeFilter === 'income' ? '收入' : typeFilter === 'both' ? '通用' : '全部类型'}}</text>
        <t-icon name="chevron-down" size="28rpx" color="#8e8e93" />
      </view>
    </picker>
    <view class="add-btn" bind:tap="openCreate">
      <t-icon name="add" size="40rpx" color="#fff" />
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading theme="dots" size="80rpx" />
  </view>
  <view wx:elif="{{categories.length === 0}}" class="empty-wrap">
    <t-icon name="tag" size="96rpx" color="#c7c7cc" />
    <text class="empty-text">暂无分类</text>
  </view>
  <view wx:else class="cat-list">
    <view wx:for="{{categories}}" wx:key="id" class="cat-item">
      <view class="cat-icon-wrap" style="background:{{item.color || '#007aff'}}">
        <t-icon name="{{item.icon || 'tag'}}" size="36rpx" color="#fff" />
      </view>
      <view class="cat-info">
        <text class="cat-name">{{item.name}}</text>
        <view class="cat-type-tag">
          <text class="cat-type-text">{{item.type === 'expense' ? '支出' : item.type === 'income' ? '收入' : '通用'}}{{item.is_system ? ' · 系统' : ''}}</text>
        </view>
      </view>
      <view class="cat-actions">
        <view bind:tap="openEdit" data-cat="{{item}}">
          <t-icon name="edit" size="36rpx" color="#8e8e93" />
        </view>
        <view wx:if="{{!item.is_system}}" bind:tap="deleteCat" data-cat="{{item}}">
          <t-icon name="delete" size="36rpx" color="#ff3b30" />
        </view>
      </view>
    </view>
  </view>

  <t-popup visible="{{dialogVisible}}" placement="bottom" bind:visible-change="closeDialog">
    <view class="dialog-sheet">
      <view class="dialog-handle"></view>
      <view class="dialog-header">
        <text class="dialog-title">{{editingCat ? '编辑分类' : '新建分类'}}</text>
        <view bind:tap="closeDialog"><t-icon name="close" size="44rpx" color="#8e8e93" /></view>
      </view>
      <view class="dialog-body">
        <view class="field-wrap">
          <text class="field-label">名称 *</text>
          <t-input placeholder="分类名称" value="{{catForm.name}}" bind:change="onNameInput" />
        </view>
        <view class="field-wrap">
          <text class="field-label">类型</text>
          <picker mode="selector" range="{{typeOptions}}" range-key="label" bind:change="onTypeChange">
            <view class="picker-btn">
              <text>{{catForm.type === 'expense' ? '支出' : catForm.type === 'income' ? '收入' : '通用'}}</text>
              <t-icon name="chevron-down" size="28rpx" color="#8e8e93" />
            </view>
          </picker>
        </view>
        <view class="field-wrap">
          <text class="field-label">颜色</text>
          <view class="color-row">
            <view wx:for="{{colorOptions}}" wx:key="*this" class="color-dot {{catForm.color === item ? 'color-dot--active' : ''}}" style="background:{{item}}" bind:tap="onColorSelect" data-color="{{item}}"></view>
          </view>
        </view>
        <t-button theme="primary" block size="large" loading="{{saving}}" bind:tap="saveCat">{{editingCat ? '更新' : '创建'}}</t-button>
      </view>
    </view>
  </t-popup>
</view>
