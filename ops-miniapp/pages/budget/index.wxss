page { background: var(--td-bg-color-page); }
.page { min-height: 100vh; }

.top-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 32rpx 20rpx;
  background: var(--td-bg-color-container);
  border-bottom: 1rpx solid var(--td-border-level-1-color);
}
.page-title { font-size: 36rpx; font-weight: 700; color: var(--td-text-color-primary); }
.top-actions { display: flex; align-items: center; gap: 20rpx; }
.action-icon { padding: 8rpx; }
.add-btn {
  width: 64rpx; height: 64rpx;
  background: var(--td-brand-color); border-radius: var(--td-radius-extra-large);
  display: flex; align-items: center; justify-content: center;
}

/* 总览 */
.overview-row {
  display: flex; gap: 1rpx;
  background: var(--td-bg-color-container); border-bottom: 1rpx solid var(--td-border-level-1-color);
  margin-bottom: 20rpx;
}
.overview-card { flex: 1; padding: 24rpx 0; text-align: center; }
.overview-label { font-size: 22rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 8rpx; }
.overview-value { font-size: 28rpx; font-weight: 700; display: block; }
.text-income { color: var(--td-success-color-6); }
.text-expense { color: var(--td-error-color-6); }

.loading-wrap { display: flex; justify-content: center; padding: 100rpx 0; }
.empty-wrap {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 0; gap: 20rpx;
}
.empty-text { font-size: 28rpx; color: var(--td-text-color-placeholder); text-align: center; padding: 0 60rpx; }

/* 钱包卡片 */
.wallets-list { padding: 0 24rpx; }
.wallet-card {
  background: var(--td-bg-color-container);
  border-radius: var(--td-radius-extra-large);
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx var(--td-shadow-1);
}
.wallet-header {
  padding: 28rpx 28rpx 32rpx;
  border-radius: var(--td-radius-extra-large) 20rpx 0 0;
}
.wallet-header-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20rpx; }
.wallet-type-wrap { display: flex; align-items: center; gap: 16rpx; }
.wallet-name-wrap { display: flex; flex-direction: column; }
.wallet-name { font-size: 32rpx; font-weight: 700; color: var(--td-bg-color-container); }
.wallet-type { font-size: 22rpx; color: rgba(255,255,255,0.75); margin-top: 4rpx; }
.wallet-right-top { display: flex; align-items: center; gap: 12rpx; }
.default-badge {
  padding: 6rpx 16rpx;
  background: rgba(255,255,255,0.25);
  border-radius: var(--td-radius-extra-large);
  font-size: 20rpx;
  color: var(--td-bg-color-container);
}
.edit-btn { padding: 4rpx; }
.wallet-balance { font-size: 48rpx; font-weight: 700; color: var(--td-bg-color-container); }

.wallet-stats {
  display: flex; padding: 20rpx 0;
}
.stat-item {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.stat-label { font-size: 22rpx; color: var(--td-text-color-secondary); }
.stat-val { font-size: 26rpx; font-weight: 600; }
.stat-divider { width: 1rpx; background: var(--td-border-level-1-color); margin: 8rpx 0; }

/* 弹窗 */
.dialog-sheet {
  background: var(--td-bg-color-container); border-radius: var(--td-radius-extra-large) 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 85vh; display: flex; flex-direction: column;
}
.dialog-handle {
  width: 80rpx; height: 8rpx; background: var(--td-border-level-1-color);
  border-radius: 4rpx; margin: 20rpx auto; flex-shrink: 0;
}
.dialog-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 40rpx 20rpx; border: 1rpx solid var(--td-border-level-1-color); flex-shrink: 0;
}
.dialog-title { font-size: 32rpx; font-weight: 600; color: var(--td-text-color-primary); }
.dialog-scroll { flex: 1; overflow: hidden; }
.dialog-body { padding: 32rpx 40rpx 40rpx; }
.field-wrap { margin-bottom: 28rpx; }
.field-label { font-size: 26rpx; color: var(--td-text-color-secondary); display: block; margin-bottom: 12rpx; }
.picker-btn {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 20rpx; background: var(--td-bg-color-page); border-radius: 12rpx;
  font-size: 28rpx; color: var(--td-text-color-primary);
}
.color-row { display: flex; gap: 16rpx; flex-wrap: wrap; }
.color-dot { width: 48rpx; height: 48rpx; border-radius: 50%; border: 4rpx solid transparent; }
.color-dot--active { border-color: var(--td-text-color-primary); transform: scale(1.2); }
.btn-row { display: flex; gap: 20rpx; margin-top: 8rpx; }
