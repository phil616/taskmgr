page {
  background: var(--td-bg-color-page);
}

.page {
  padding: 0 0 120rpx;
}

/* 顶部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  background: var(--td-bg-color-container);
  border-bottom-left-radius: var(--td-radius-large);
  border-bottom-right-radius: var(--td-radius-large);
  margin-bottom: 24rpx;
  box-shadow: var(--td-shadow-1);
}
.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--td-text-color-primary);
}
.header-sub {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  display: block;
  margin-top: 8rpx;
}
.notif-btn {
  padding: 12rpx;
}

/* 加载 */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 0 32rpx 24rpx;
}
.stat-card {
  border-radius: var(--td-radius-extra-large);
  padding: 32rpx 24rpx;
  position: relative;
  overflow: hidden;
  min-height: 160rpx;
  box-shadow: var(--td-shadow-1);
}
.stat-primary { background: linear-gradient(135deg, #007aff, #005ce6); }
.stat-error   { background: linear-gradient(135deg, #ff3b30, #d92b22); }
.stat-warning { background: linear-gradient(135deg, #ff9500, #d97800); }
.stat-info    { background: linear-gradient(135deg, #34c759, #28a745); }

.stat-num {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--td-bg-color-container);
  line-height: 1;
}
.stat-label {
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.9);
  margin-top: 12rpx;
}
.stat-icon {
  position: absolute;
  right: -8rpx;
  bottom: -8rpx;
  opacity: 0.8;
}

/* 卡片区块 */
.section-card {
  margin: 0 32rpx 32rpx;
  background: var(--td-bg-color-container);
  border-radius: var(--td-radius-extra-large);
  overflow: hidden;
  box-shadow: var(--td-shadow-1);
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--td-border-level-1-color);
}
.section-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--td-text-color-primary);
}
.section-more {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--td-brand-color);
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 16rpx;
}
.empty-text {
  font-size: 26rpx;
  color: var(--td-text-color-placeholder);
}

/* 告警单元 */
.unit-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--td-border-level-1-color);
  position: relative;
}
.unit-item:last-child { border-bottom: none; }
.unit-indicator {
  width: 8rpx;
  height: 64rpx;
  border-radius: var(--td-radius-round);
  margin-right: 20rpx;
  flex-shrink: 0;
}
.unit-info {
  flex: 1;
  min-width: 0;
}
.unit-name {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  display: block;
  font-weight: 500;
}
.unit-time {
  font-size: 26rpx;
  color: var(--td-text-color-secondary);
  display: block;
  margin-top: 6rpx;
}
.unit-badge {
  padding: 8rpx 20rpx;
  border-radius: var(--td-radius-round);
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* 待办事项 */
.todo-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--td-border-level-1-color);
}
.todo-item:last-child { border-bottom: none; }
.todo-check {
  padding: 4rpx 16rpx 0 0;
  flex-shrink: 0;
}
.todo-info { flex: 1; min-width: 0; }
.todo-title {
  font-size: 30rpx;
  color: var(--td-text-color-primary);
  display: block;
  line-height: 1.5;
}
.todo-done {
  text-decoration: line-through;
  color: var(--td-text-color-placeholder);
}
.todo-due {
  font-size: 24rpx;
  color: var(--td-text-color-secondary);
  display: block;
  margin-top: 6rpx;
}