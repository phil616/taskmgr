# =============================================================================
# ops-task-manager-backend 环境变量模板（前缀 TASK_MANAGER_）
# 用法：复制为 .env 放在可执行文件同目录，或 export 后启动 ./opstaskmanager
# 列表类：多个值用英文逗号分隔（如 CORS）
# =============================================================================

# --- server ---
TASK_MANAGER_SERVER_HOST=0.0.0.0
TASK_MANAGER_SERVER_PORT=8080
# TASK_MANAGER_SERVER_CORS_ORIGINS=http://localhost:5173,http://localhost

# --- database ---
TASK_MANAGER_DATABASE_DRIVER=sqlite
TASK_MANAGER_DATABASE_DSN=./data/task_manager.db

# --- auth ---
TASK_MANAGER_AUTH_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
TASK_MANAGER_AUTH_JWT_EXPIRY_HOURS=24
TASK_MANAGER_AUTH_LOGIN_LOCK_ATTEMPTS=5
TASK_MANAGER_AUTH_LOGIN_LOCK_MINUTES=15

# --- scheduler ---
TASK_MANAGER_SCHEDULER_NOTIFICATION_SCAN_INTERVAL=10m

# --- mcp ---
TASK_MANAGER_MCP_ENABLED=true
TASK_MANAGER_MCP_PATH=/mcp
# 对外可访问地址（用于 GET /mcp/config 生成客户端配置片段，留空则自动检测）
# TASK_MANAGER_MCP_EXTERNAL_URL=https://your-domain.com
TASK_MANAGER_MCP_SERVER_NAME=ops-timer-mcp
TASK_MANAGER_MCP_SERVER_VERSION=2.0.0
TASK_MANAGER_MCP_TIMEOUT_SECONDS=30

# --- smtp（host 与 from 均非空时启用邮件；否则跳过）---
# TASK_MANAGER_SMTP_HOST=smtp.example.com
TASK_MANAGER_SMTP_PORT=587
# TASK_MANAGER_SMTP_USERNAME=
# TASK_MANAGER_SMTP_PASSWORD=
# TASK_MANAGER_SMTP_FROM=运维任务管理器 <noreply@example.com>

# --- log ---
TASK_MANAGER_LOG_LEVEL=info
TASK_MANAGER_LOG_FORMAT=json
